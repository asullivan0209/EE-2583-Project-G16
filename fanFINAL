void fanMAIN (void){ // main fan code to activate based on "temp" values
    
    // setup pins for 2n2222a
    TRISC2 = 0;   // set rc2 as output
    ANSC2 = 0;   // disable rc2 analog
    int temp = 85;
    
    while(1){
        if(temp>25){    // sets temp threshold for fan activation
            LATC2 = 1;}
        else{
            LATC2 = 0;} // remains off otherwise
    }
}
