#pragma config STVREN = ON      // Stack Overflow/Underflow Reset Enable 
#pragma config BORV = LO        // Brown-out Reset Voltage Selection low
#pragma config LVP = ON        // Low-Voltage Programming Enabled

#include <xc.h>  
#include <stdio.h>  
#include <stdlib.h>  

  
#define _XTAL_FREQ 4000000.0    /*for 4mhz*/
/*Serial Configuration*/
#define BAUD 9600   //Bits per second transfer rate
#define FOSC 4000000L   //Frequency Oscillator
#define DIVIDER ((int)(FOSC/(16UL * BAUD) -1))  //Should be 25 for 9600/4MhZ
#define NINE_BITS 0
#define SPEED 0x4       //T Speed
#define RX_PIN TRISC5   //Recieve Pin
#define TX_PIN TRISC4   //Transmit Pin


// ---------- VARIABLES ----------
unsigned int adcValue = 0;
float voltage = 0;
float temperatureC = 0;

// ---------- PROTOTYPES ----------
unsigned int readTempSensor(void);
void putch(char data);

// ---------- MAIN ----------
void main(void)
{
    OSCCON = 0x6A;

    // UART setup
    TRISC4 = 0;
    TRISC5 = 1;
    ANSELC = 0x00;

    APFCON0bits.TXCKSEL = 1;
    APFCON0bits.RXDTSEL = 1;

    TXSTA = 0x24;
    RCSTA = 0x90;
    BAUDCON = 0x08;
    SPBRG = 25;

    // ADC setup
    ADCON1 = 0x80;
    ADCON0bits.ADON = 1;

    while(1)
    {
        adcValue = readTempSensor();

        // Convert ADC → Voltage
        voltage = (adcValue * 5.0) / 1023.0;

        // MCP9700F conversion
        temperatureC = (voltage - 0.5) * 100.0;

        // Print temperature (comment out)
        printf("Temperature = %.2f C\r\n", temperatureC);

        __delay_ms(500);
    }
}

// ---------- ADC READ ----------
unsigned int readTempSensor(void)
{
    ADCON0 = 0x19;   // Temp sensor channel (same as your original)

    __delay_ms(2);

    ADGO = 1;
    while(ADGO);

    return ((unsigned int)ADRESH << 8) + ADRESL;
}

// ---------- UART ----------
void putch(char data)
{
    while(!TXIF);
    TXREG = data;
}
