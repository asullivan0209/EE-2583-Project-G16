#include <xc.h>  
#include <stdio.h>  
#include <stdlib.h>  

  
#define _XTAL_FREQ 4000000.0    /*for 4mhz*/
/*Serial Configuration*/
#define BAUD 9600   //Bits per second transfer rate
#define FOSC 4000000L   //Frequency Oscillator
#define DIVIDER ((int)(FOSC/(16UL * BAUD) -1))  //Should be 25 for 9600/4MhZ
#define NINE_BITS 0
#define SPEED 0x4       //T Speed
#define RX_PIN TRISC5   //Recieve Pin
#define TX_PIN TRISC4   //Transmit Pin

// ===== FUNCTION PROTOTYPES =====
unsigned int readPot(void);
void putch(char data);

// ===== GLOBAL (STORED VALUE) =====
unsigned int potValue = 0;
float temperatureC = 0;

// ===== MAIN =====
void main(void)
{
    // ===== CLOCK =====
    OSCCON = 0x6A;

    // ===== POT SETUP (AN11 / RB5) =====
    TRISB5 = 1;
    ANSELBbits.ANSB5 = 1;

    // ===== UART =====
    TRISC4 = 0;
    TRISC5 = 1;
    ANSELC = 0x00;

    APFCON0bits.TXCKSEL = 1;
    APFCON0bits.RXDTSEL = 1;

    TXSTA = 0x24;
    RCSTA = 0x90;
    BAUDCON = 0x08;
    SPBRG = 25;

    // ===== ADC =====
    ADCON1 = 0x80;
    ADCON0bits.ADON = 1;

    while(1)
    {
        // -------------------------
        // READ + STORE VALUE
        // -------------------------
        potValue = readPot();

        // convert to "temperature"
        temperatureC = (potValue * 50.0) / 1023.0;

        // -------------------------
        // PRINT (COMMENT THIS OUT)
        // -------------------------
        printf("Temperature = %.2f C\r\n", temperatureC);

        __delay_ms(500);
    }
}

// ===== ADC READ =====
unsigned int readPot(void)
{
    ADCON0bits.CHS = 0b01011; // AN11 (RB5)

    __delay_ms(2);

    ADGO = 1;
    while(ADGO);

    return ((unsigned int)ADRESH << 8) + ADRESL;
}

// ===== UART =====
void putch(char data)
{
    while(!TXIF);
    TXREG = data;
}

